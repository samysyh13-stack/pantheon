    "@use-gesture/react": "^10.3.1",
    "dexie": "^4.4.2",
    "howler": "^2.2.4",
    "immer": "^11.1.4",
    "postprocessing": "^6.39.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "three": "^0.184.0",
    "three-custom-shader-material": "^6.4.0",
    "three-stdlib": "^2.36.1",
    "tone": "^15.1.22",
